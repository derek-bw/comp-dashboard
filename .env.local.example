# Google Sheets API key (restrict to Sheets API in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here

# The Google Sheet ID (from the spreadsheet URL)
# e.g. https://docs.google.com/spreadsheets/d/SHEET_ID/edit
# SHEET_ID is now hardcoded in lib/sheetsClient.ts

# Required Sheet tabs (must exist in the spreadsheet):
#   Rep_Manager_Map       — A:B  (repName, managerName)
#   App_Rep_Summary       — A:AM (identity + metrics + new cols)
#   App_Deal_Detail       — A:Y  (deal rows + new cols)
#   App_MPE_Summary       — A:Z  (MPE / promotion data)
#   App_Team_Summary      — A:J  (per-rep rows per manager)
#   App_Manager_Rollup    — A:S  (one row per manager per month)
#   Calculator_Config     — A:H  (payout multipliers)
